#!/usr/bin/env python3
"""
MyAgent Hub CLI 入口点

用法:
    myagent                    # 启动 Hub
    myagent --help            # 显示帮助
    myagent --version         # 显示版本
"""

import sys
import argparse
from pathlib import Path

# 添加项目根目录到路径
sys.path.insert(0, str(Path(__file__).parent.parent))

from hub.main import app, HOST, PORT, WS_PORT


def main():
    parser = argparse.ArgumentParser(
        description="MyAgent Hub - 本地 AI Agent 调度中心",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  myagent                    # 启动 Hub (默认端口 8080/8765)
  myagent --port 9000        # 自定义 HTTP 端口
  myagent --ws 9001          # 自定义 WebSocket 端口
  myagent --host 127.0.0.1   # 仅监听本地
        """
    )
    
    parser.add_argument(
        '--version', '-v',
        action='version',
        version='MyAgent Hub 1.0.0'
    )
    
    parser.add_argument(
        '--host',
        default=HOST,
        help=f'监听地址 (默认: {HOST})'
    )
    
    parser.add_argument(
        '--port', '-p',
        type=int,
        default=PORT,
        help=f'HTTP 端口 (默认: {PORT})'
    )
    
    parser.add_argument(
        '--ws',
        type=int,
        default=WS_PORT,
        help=f'WebSocket 端口 (默认: {WS_PORT})'
    )
    
    parser.add_argument(
        '--reload',
        action='store_true',
        help='启用热重载 (开发模式)'
    )
    
    args = parser.parse_args()
    
    # 启动服务
    import uvicorn
    
    print("=" * 50)
    print("  MyAgent Hub")
    print("=" * 50)
    print(f"  HTTP:      http://{args.host}:{args.port}")
    print(f"  WebSocket: ws://{args.host}:{args.ws}")
    print("=" * 50)
    
    uvicorn.run(
        "hub.main:app",
        host=args.host,
        port=args.port,
        ws="wsproto",
        reload=args.reload,
        log_level="info"
    )


if __name__ == "__main__":
    main()
